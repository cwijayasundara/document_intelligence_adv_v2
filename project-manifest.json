{
  "name": "PE Document Intelligence Platform",
  "description": "Document intelligence platform for private equity — processes LPA and Subscription Agreement documents through upload, parse, edit, classify, extract, summarize, ingest, and retrieve workflows.",
  "stack": {
    "backend": {
      "language": "python",
      "version": "3.13",
      "framework": "fastapi",
      "package_manager": "uv",
      "linter": "ruff",
      "typechecker": "mypy",
      "test_runner": "pytest"
    },
    "frontend": {
      "language": "typescript",
      "framework": "react",
      "bundler": "vite",
      "version": "19",
      "package_manager": "npm",
      "linter": "eslint",
      "typechecker": "tsc",
      "test_runner": "vitest"
    },
    "database": {
      "primary": "postgresql",
      "secondary": "weaviate"
    },
    "deployment": {
      "method": "docker-compose",
      "services": ["postgres", "weaviate"]
    }
  },
  "evaluation": {
    "api_base_url": "http://localhost:8000",
    "ui_base_url": "http://localhost:5173",
    "health_check": "http://localhost:8000/api/v1/health",
    "design_score_threshold": 7,
    "design_max_iterations": 10,
    "test_corpus_dir": "docs/"
  },
  "execution": {
    "default_mode": "full",
    "max_self_heal_attempts": 3,
    "max_auto_iterations": 50,
    "coverage_threshold": 80,
    "session_chaining": true,
    "agent_team_size": "auto",
    "teammate_model": "sonnet"
  },
  "verification": {
    "mode": "local",
    "health_check": {
      "url": "http://localhost:8000/api/v1/health",
      "retries": 5,
      "backoff_seconds": 2
    },
    "local": {
      "backend_url": "http://localhost:8000",
      "frontend_url": "http://localhost:5173",
      "start_commands": [
        "cd backend && uv run uvicorn src.main:app --reload --port 8000",
        "cd frontend && npm run dev"
      ]
    }
  }
}
