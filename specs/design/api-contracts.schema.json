                "$ref": "#/components/schemas/UpsertFieldsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Fields upserted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UpsertFieldsResponse"
                }
              }
            }
          },
          "404": {
            "description": "Category not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/bulk/upload": {
      "post": {
        "operationId": "bulkUpload",
        "summary": "Start a bulk processing job",
        "tags": ["Bulk"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "files": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    }
                  }
                },
                "required": ["files"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Bulk job created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkJobCreateResponse"
                }
              }
            }
          }
        }
      }
    },
    "/bulk/jobs": {
      "get": {
        "operationId": "listBulkJobs",
        "summary": "List all bulk jobs",
        "tags": ["Bulk"],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["pending", "processing", "completed", "failed", "partial_failure"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkJobListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/bulk/jobs/{id}": {
      "get": {
        "operationId": "getBulkJob",
        "summary": "Get bulk job details with per-document progress",
        "tags": ["Bulk"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkJobDetailResponse"
                }
              }
            }
          },
          "404": {
            "description": "Job not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "required": ["detail", "error_code"],
        "properties": {
          "detail": {
            "type": "string"
          },
          "error_code": {
            "type": "string"
          },
          "context": {
            "type": "object"
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": ["status", "version", "dependencies"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["healthy", "degraded"]
          },
          "version": {
            "type": "string"
          },
          "dependencies": {
            "type": "object",
            "properties": {
              "database": {
                "type": "string"
              },
              "weaviate": {
                "type": "string"
              }
            }
          }
        }
      },
      "DocumentResponse": {
        "type": "object",
        "required": ["id", "file_name", "original_path", "file_hash", "status", "file_type", "file_size", "created_at", "updated_at"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "file_name": {
            "type": "string"
          },
          "original_path": {
            "type": "string"
          },
          "parsed_path": {
            "type": "string",
            "nullable": true
          },
          "file_hash": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["uploaded", "parsed", "edited", "classified", "extracted", "summarized", "ingested"]
          },
          "document_category_id": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "file_type": {
            "type": "string"
          },
          "file_size": {
            "type": "integer",
            "format": "int64"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
