# ==============================================
# PE Document Intelligence Platform
# Copy this file to .env and fill in your values
# ==============================================

# OpenAI API key — used by all LLM agents (classifier, extractor, judge, summarizer, RAG)
OPENAI_API_KEY=sk-...

# OpenAI model — the model used for all agent calls
OPENAI_MODEL=gpt-4o-mini

# Reducto Cloud API key — used for document parsing (PDF, DOCX, XLSX, images → markdown)
REDUCTO_API_KEY=...

# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://doc_intel:doc_intel_dev@localhost:5432/doc_intel

# PostgreSQL password — used by docker-compose for the postgres container
POSTGRES_PASSWORD=doc_intel_dev

# Weaviate instance URL — used for vector storage and hybrid search
WEAVIATE_URL=http://localhost:8080
